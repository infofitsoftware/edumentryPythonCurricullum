  <name><text>M2-Q02 dynamic typing</text></name>
  <questiontext format="html">
    <text><![CDATA[<p>What does <strong>dynamic typing</strong> mean in Python?</p>]]></text>
  </questiontext>
  <generalfeedback format="html">
    <text><![CDATA[<p>Dynamic typing means the type is determined by the assigned value and can change when the variable is reassigned.</p>]]></text>
