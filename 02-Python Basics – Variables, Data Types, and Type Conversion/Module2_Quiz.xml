<!-- Question 1 -->
<question type="multichoice">
  <name><text>M2-Q01 variable definition</text></name>
  <questiontext format="html">
    <text><![CDATA[<p>What is a variable in Python?</p>]]></text>
  </questiontext>
  <generalfeedback format="html">
    <text><![CDATA[<p>A variable is a name that refers to a value stored in memory. It is created when you assign a value with <code>=</code>.</p>]]></text>
  </generalfeedback>
  <defaultgrade>1.0000000</defaultgrade>
  <penalty>0.3333333</penalty>
  <hidden>0</hidden>
  <single>true</single>
  <shuffleanswers>1</shuffleanswers>
  <answernumbering>abc</answernumbering>
  <correctfeedback format="html"><text>Correct!</text></correctfeedback>
  <incorrectfeedback format="html"><text>Incorrect.</text></incorrectfeedback>
  <answer fraction="100" format="html"><text>A name that refers to a value in memory</text></answer>
  <answer fraction="0" format="html"><text>A fixed container that cannot change type</text></answer>
  <answer fraction="0" format="html"><text>A function that prints output</text></answer>
